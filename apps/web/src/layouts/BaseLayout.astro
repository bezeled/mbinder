---
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Navigation from "@/components/global/navigation/Navigation.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  seo?: {
    title?: string;
    description?: string;
    image?: { url: string; alt?: string };
    type?: "website" | "article";
    publishedTime?: string;
    noindex?: boolean;
  };
  hideNavigation?: boolean;
  hideFooter?: boolean;
  bodyClass?: string;
}

const {
  seo,
  hideNavigation = false,
  hideFooter = false,
  bodyClass = "",
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead seo={seo} />
  </head>
  <body class={`flex flex-col bg-wall min-h-svh text-ink ${bodyClass}`}>
    {!hideNavigation && <Navigation />}
    <main class="grow min-w-0"><slot /></main>
    {!hideFooter && <Footer />}
  </body>
</html>
