---
import { getPageUrl } from "@/lib/listing/pagination";

const {
  basePath,
  currentPage,
  totalPages,
} = Astro.props as {
  basePath: string;
  currentPage: number;
  totalPages: number;
};

const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
const previousPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
---

{totalPages > 1 && (
  <nav class="mt-16 border-t border-divider pt-8" aria-label="Pagination">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="mono-label text-ink-muted">
        Page {currentPage} of {totalPages}
      </p>

      <div class="flex flex-wrap items-center gap-2">
        {previousPage ? (
          <a
            href={getPageUrl(basePath, previousPage)}
            class="inline-flex min-h-10 items-center border border-divider px-4 text-sm font-medium text-ink transition-colors hover:bg-linen-dark"
          >
            Previous
          </a>
        ) : (
          <span class="inline-flex min-h-10 items-center border border-divider/50 px-4 text-sm font-medium text-ink-muted/60">
            Previous
          </span>
        )}

        {pages.map((page) => (
          <a
            href={getPageUrl(basePath, page)}
            aria-current={page === currentPage ? "page" : undefined}
            class:list={[
              "inline-flex min-h-10 min-w-10 items-center justify-center border px-3 text-sm font-medium transition-colors",
              page === currentPage
                ? "border-ink bg-ink text-white"
                : "border-divider text-ink hover:bg-linen-dark",
            ]}
          >
            {page}
          </a>
        ))}

        {nextPage ? (
          <a
            href={getPageUrl(basePath, nextPage)}
            class="inline-flex min-h-10 items-center border border-divider px-4 text-sm font-medium text-ink transition-colors hover:bg-linen-dark"
          >
            Next
          </a>
        ) : (
          <span class="inline-flex min-h-10 items-center border border-divider/50 px-4 text-sm font-medium text-ink-muted/60">
            Next
          </span>
        )}
      </div>
    </div>
  </nav>
)}
