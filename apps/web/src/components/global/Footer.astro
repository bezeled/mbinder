---
import Wrapper from "../fundations/containers/Wrapper.astro";
import Wordmark from "../fundations/icons/Wordmark.astro";

const navColumns = [
  {
    title: "Product",
    links: [
      { name: "Marketplace", href: "/marketplace" },
      { name: "Products", href: "/products" },
      { name: "Try MemoryBinder", href: "/waitlist" },
    ],
  },
  {
    title: "Story",
    links: [
      { name: "Vision", href: "/vision" },
      { name: "Trust", href: "/trust" },
      { name: "Blog", href: "/blog" },
      { name: "Announcements", href: "/announcements" },
    ],
  },
  {
    title: "Learn",
    links: [
      { name: "Memories", href: "/learn/memories" },
      { name: "Wallets & Walls", href: "/learn/wallets" },
      { name: "Registry", href: "/registry" },
    ],
  },
  {
    title: "Designs",
    links: [
      { name: "Main", href: "/" },
      { name: "Yin yang", href: "/two" },
      { name: "Main app", href: "/three" },
      { name: "All alts", href: "/alt-designs" },
    ],
  },
  {
    title: "Legal",
    links: [
      { name: "Privacy", href: "/legal/privacy" },
      { name: "Terms", href: "/legal/terms" },
      { name: "Contact", href: "/contact" },
    ],
  },
];
---

<footer class="z-0 w-full border-t border-divider pb-[env(safe-area-inset-bottom,0px)] bg-wall">
  <Wrapper variant="standard" class="py-20 lg:py-28">
    <!-- Mobile compact -->
    <div class="flex flex-col gap-6 md:hidden">
      <a href="/" class="inline-flex">
        <Wordmark size="md" variant="duo" />
      </a>
      <p class="text-sm text-ink-muted leading-relaxed max-w-[28ch]">
        Your story. Your asset. Legally.
      </p>
      <nav class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm text-ink-muted mt-2">
        <a href="/marketplace" class="hover:text-mb-pink transition-colors">Marketplace</a>
        <a href="/vision" class="hover:text-mb-pink transition-colors">Vision</a>
        <a href="/products" class="hover:text-mb-pink transition-colors">Products</a>
        <a href="/learn" class="hover:text-mb-pink transition-colors">Learn</a>
        <a href="/trust" class="hover:text-mb-pink transition-colors">Trust</a>
        <a href="/blog" class="hover:text-mb-pink transition-colors">Blog</a>
        <a href="/registry" class="hover:text-mb-pink transition-colors">Registry</a>
        <a href="/alt-designs" class="hover:text-mb-pink transition-colors">Alt designs</a>
      </nav>
      <hr class="border-divider my-2" />
      <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-ink-muted">
        <a href="/legal/privacy" class="hover:text-mb-pink transition-colors">Privacy</a>
        <a href="/legal/terms" class="hover:text-mb-pink transition-colors">Terms</a>
        <a href="/contact" class="hover:text-mb-pink transition-colors">Contact</a>
      </nav>
      <p class="text-[11px] text-ink-muted mt-3">
        &copy; {new Date().getFullYear()} MemoryBinder Pty Ltd. All rights reserved.
      </p>
    </div>

    <!-- Desktop -->
    <div class="hidden md:block">
      <div class="grid grid-cols-12 gap-x-10 gap-y-12">
        <div class="col-span-12 lg:col-span-4 flex flex-col gap-5">
          <a href="/" class="inline-flex">
            <Wordmark size="md" variant="duo" />
          </a>
          <p class="text-base text-ink leading-relaxed max-w-[32ch]">
            Your story. Your asset. Legally.
          </p>
          <p class="text-sm text-ink-muted leading-relaxed max-w-[34ch]">
            The legal property infrastructure for personal data, memories,
            and consumer AI agents.
          </p>
        </div>

        <div class="col-span-12 lg:col-span-8">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-8 gap-y-10">
            {navColumns.map((col) => (
              <div>
                <p class="text-sm font-grotesk font-semibold text-ink mb-4">{col.title}</p>
                <nav class="flex flex-col gap-2.5">
                  {col.links.map((link) => (
                    <a
                      href={link.href}
                      class="text-sm text-ink-muted hover:text-mb-pink transition-colors"
                    >
                      {link.name}
                    </a>
                  ))}
                </nav>
              </div>
            ))}
          </div>
        </div>
      </div>

      <hr class="section-rule mt-16 lg:mt-20 mb-6" />

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-xs text-ink-muted">
        <p>&copy; {new Date().getFullYear()} MemoryBinder Pty Ltd. All rights reserved.</p>
        <p>Made with care in Sydney.</p>
      </div>
    </div>
  </Wrapper>
</footer>
