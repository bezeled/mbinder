---
interface Props {
  current: "v1" | "v2" | "v3";
}
const { current } = Astro.props;
const variants = [
  { id: "v1", href: "/", label: "V1 — Editorial" },
  { id: "v2", href: "/two", label: "V2 — Yin Yang" },
  { id: "v3", href: "/three", label: "V3 — Marketplace" },
];
---
<div class="fixed bottom-4 left-1/2 -translate-x-1/2 z-40 flex items-center gap-1.5 px-2 py-1.5 rounded-full bg-wall/90 backdrop-blur border border-divider shadow-[0_8px_24px_-12px_rgba(11,11,11,0.18)]">
  <span class="mono-label text-ink-muted px-2 hidden sm:inline">design</span>
  {variants.map((v) => (
    <a
      href={v.href}
      class="iter-pill"
      aria-current={current === v.id ? "page" : undefined}
    >
      {v.label}
    </a>
  ))}
</div>
