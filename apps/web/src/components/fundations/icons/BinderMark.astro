---
interface Props {
  size?: number | string;
  variant?: "duo" | "ink" | "pink" | "teal" | "purple" | "duo-purple" | "duo-ink";
  class?: string;
  ariaLabel?: string;
  glow?: boolean;
}
const {
  size = 48,
  variant = "duo",
  class: className = "",
  ariaLabel = "MemoryBinder mark",
  glow = true,
} = Astro.props;
const dim = typeof size === "number" ? `${size}px` : size;

let left = "var(--color-mb-pink)";
let right = "var(--color-mb-teal)";
if (variant === "ink") { left = right = "var(--color-ink)"; }
if (variant === "pink") { left = right = "var(--color-mb-pink)"; }
if (variant === "teal") { left = right = "var(--color-mb-teal)"; }
if (variant === "purple") { left = right = "var(--color-mb-purple)"; }
if (variant === "duo-purple") { left = "var(--color-mb-pink)"; right = "var(--color-mb-purple)"; }
if (variant === "duo-ink") { left = "var(--color-mb-pink)"; right = "var(--color-ink)"; }

// Split infinity: two interlocking oval loops, chain-link weave.
// Loops are taller than wide so the silhouette reads as ∞ but with a real link
// in the middle — the right edge of the left loop crosses over the right loop.
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 72 40"
  width={dim}
  height="auto"
  class={`${glow ? "binder-glow" : ""} ${className}`}
  role="img"
  aria-label={ariaLabel}
>
  <g transform="rotate(-6 36 20)">
    <!-- Left loop -->
    <ellipse
      cx="25"
      cy="20"
      rx="13"
      ry="15"
      fill="none"
      stroke={left}
      stroke-width="4.6"
      stroke-linejoin="round"
    />
    <!-- Right loop -->
    <ellipse
      cx="47"
      cy="20"
      rx="13"
      ry="15"
      fill="none"
      stroke={right}
      stroke-width="4.6"
      stroke-linejoin="round"
    />
    <!-- Weave: redraw the inner half of the left loop on top of the right loop
         so the two genuinely interlock instead of just overlapping. -->
    <path
      d="M 36 6.4 A 13 15 0 0 1 38 20 A 13 15 0 0 1 36 33.6"
      fill="none"
      stroke={left}
      stroke-width="4.6"
      stroke-linecap="round"
    />
  </g>
</svg>
