---
interface Props {
  size?: number | string;
  variant?: "duo" | "ink" | "pink" | "teal" | "purple" | "duo-purple" | "duo-ink";
  class?: string;
  ariaLabel?: string;
  glow?: boolean;
}
const {
  size = 48,
  variant = "duo",
  class: className = "",
  ariaLabel = "MemoryBinder mark",
  glow = true,
} = Astro.props;
const dim = typeof size === "number" ? `${size}px` : size;

let left = "var(--color-mb-pink)";
let right = "var(--color-mb-teal)";
if (variant === "ink") { left = right = "var(--color-ink)"; }
if (variant === "pink") { left = right = "var(--color-mb-pink)"; }
if (variant === "teal") { left = right = "var(--color-mb-teal)"; }
if (variant === "purple") { left = right = "var(--color-mb-purple)"; }
if (variant === "duo-purple") { left = "var(--color-mb-pink)"; right = "var(--color-mb-purple)"; }
if (variant === "duo-ink") { left = "var(--color-mb-pink)"; right = "var(--color-ink)"; }

// Two interlocking rings — bound, not infinite.
// Slight clockwise tilt for couture-wonky feel.
// Stroke widths chosen for legibility at favicon sizes.
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 36"
  width={dim}
  height="auto"
  class={`${glow ? "binder-glow" : ""} ${className}`}
  role="img"
  aria-label={ariaLabel}
>
  <g transform="rotate(-4 32 18)">
    <!-- Left ring (typically pink) -->
    <circle
      cx="22"
      cy="18"
      r="13"
      fill="none"
      stroke={left}
      stroke-width="4.4"
    />
    <!-- Right ring (typically teal) -->
    <circle
      cx="42"
      cy="18"
      r="13"
      fill="none"
      stroke={right}
      stroke-width="4.4"
    />
    <!-- Weave: redraw the right side of the left ring on top of the right ring,
         so the two rings actually look interlinked rather than just side-by-side. -->
    <path
      d="M 32 5.5 A 13 13 0 0 1 35 18 A 13 13 0 0 1 32 30.5"
      fill="none"
      stroke={left}
      stroke-width="4.4"
      stroke-linecap="round"
    />
  </g>
</svg>
