---
/** Renders `public/icon.svg`; `variant` is accepted for backwards compatibility only. */
interface Props {
  size?: number | string;
  variant?: "duo" | "ink" | "pink" | "teal" | "purple" | "duo-purple" | "duo-ink";
  class?: string;
  decorative?: boolean;
  ariaLabel?: string;
  glow?: boolean;
}
const {
  size = 48,
  variant: _variant = "duo",
  class: className = "",
  decorative = false,
  ariaLabel = "MemoryBinder mark",
  glow = true,
} = Astro.props;
void _variant;
const dim = typeof size === "number" ? `${size}px` : size;
---
<img
  src="/icon.svg"
  alt={decorative ? "" : ariaLabel}
  decoding="async"
  width={134}
  height={74}
  class={`${glow ? "binder-glow" : ""} h-auto max-w-none ${className}`.trim()}
  style={`width: ${dim}; height: auto;`}
  draggable="false"
/>
