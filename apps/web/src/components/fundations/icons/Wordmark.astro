---
import BinderMark from "@/components/fundations/icons/BinderMark.astro";

interface Props {
  size?: "sm" | "md" | "lg";
  variant?: "duo" | "ink" | "duo-purple" | "duo-ink";
  showWord?: boolean;
  wordVariant?: "duo" | "ink";
  class?: string;
}
const {
  size = "md",
  variant = "duo",
  showWord = true,
  wordVariant = "duo",
  class: className = "",
} = Astro.props;

const sizeMap = {
  sm: { mark: 26, text: "text-[1rem]" },
  md: { mark: 34, text: "text-[1.2rem]" },
  lg: { mark: 56, text: "text-[2rem]" },
};
const s = sizeMap[size];
void variant;
---
<span class={`logo-wordmark group/logo font-grotesk font-semibold tracking-tight text-ink ${className}`}>
  <BinderMark size={s.mark} variant="duo" decorative={showWord} ariaLabel="MemoryBinder" glow={false} />
  {showWord && (
    <span class={`relative z-10 leading-none ${s.text}`}>
      {wordVariant === "duo" ? (
        <span class="text-ink tracking-tight"
          ><span class="font-semibold text-mb-teal">Memory</span><span class="font-semibold text-ink">Binder</span></span
        >
      ) : (
        <span class="text-ink font-semibold">MemoryBinder</span>
      )}
    </span>
  )}
  <span class="logo-glow"></span>
</span>
