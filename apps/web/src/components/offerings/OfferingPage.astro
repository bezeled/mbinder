---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import { portableTextToHtml } from "@/lib/sanity";
import type { Product, Service } from "@/lib/sanity";

interface Props {
  kind: "product" | "service";
  cmsOffering: Product | Service;
}

const { kind, cmsOffering } = Astro.props;

const title = cmsOffering.data.title;
const shortName = cmsOffering.data.shortName;
const subtitle = cmsOffering.data.subtitle;
const order = cmsOffering.data.order;
const description = cmsOffering.data.description;
const ctaText = cmsOffering.data.ctaText;
const steps = cmsOffering.data.steps || [];
const pullQuote = cmsOffering.data.pullQuote;
const caseStudy = cmsOffering.data.caseStudy;
const bodyHtml =
  cmsOffering.body && cmsOffering.body.length > 0
    ? portableTextToHtml(cmsOffering.body)
    : "";
const image = cmsOffering.data.image;
const imageAspectClass =
  cmsOffering.slug === "d-val"
    ? "aspect-[4/3]"
    : cmsOffering.slug === "las"
      ? "aspect-square"
      : "aspect-[4/5]";
const heroAccent = kind === "product" ? "geo-circle" : "geo-rect";
const heroAccentStyle =
  kind === "product"
    ? "width: 520px; height: 520px; top: -100px; right: -180px;"
    : "width: 300px; height: 400px; top: -60px; right: -100px;";
---

<BaseLayout seo={{ title }}>
  <section class="relative overflow-hidden">
    <div class:list={["hidden lg:block", heroAccent]} style={heroAccentStyle}></div>
    <Wrapper variant="standard" class="pt-24 pb-16 lg:pt-36 lg:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20 items-start">
        <div class="lg:col-span-3">
          <p class="mono-label text-ink-muted mb-6">
            {String(order).padStart(2, "0")} — {shortName} · {subtitle}
          </p>
          <h1 class="page-hero-title text-ink">{title}</h1>
        </div>
        <div class="lg:col-span-2 lg:pt-16">
          <p class="text-base leading-relaxed text-ink-muted">{description}</p>
          <a
            href="/contact"
            class="responsive-cta mt-8 bg-ink text-white text-sm font-medium px-6 py-3 hover:bg-ink-light transition-colors"
          >
            Contact Sales
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Wrapper>
  </section>

  {(steps.length > 0 || image?.url) && (
    <section>
      <SectionRule />
      <Wrapper variant="standard" class="py-20 lg:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          {steps.length > 0 && (
            <div>
              <p class="mono-label text-ink-muted mb-8">HOW IT WORKS</p>
              <div class="flex flex-col gap-8">
                {steps.map((step: { label: string; description: string }) => (
                  <div class="border-t border-divider pt-6">
                    <p class="mono-label text-ink font-medium mb-3">{step.label}</p>
                    <p class="text-sm text-ink-muted leading-relaxed">{step.description}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
          {image?.url && (
            <div class="relative flex items-center justify-center min-h-[280px] sm:min-h-[360px] lg:min-h-[480px]">
              <img
                src={image.url}
                alt={image.alt || title}
                class:list={["w-full max-w-[420px] object-cover object-center border border-ghost-stroke", imageAspectClass]}
                loading="lazy"
              />
            </div>
          )}
        </div>
      </Wrapper>
    </section>
  )}

  {bodyHtml && (
    <section>
      <SectionRule />
      <Wrapper variant="standard" class="py-20 lg:py-28">
        <div class="max-w-2xl">
          <p class="mono-label text-ink-muted mb-8">THE PRACTICE</p>
          <div
            class="prose prose-sm max-w-none text-ink-muted leading-relaxed"
            set:html={bodyHtml}
          />
        </div>
      </Wrapper>
    </section>
  )}

  <section class="relative overflow-hidden">
    <SectionRule />
    <svg class="w-full" viewBox="0 0 1200 160" fill="none" preserveAspectRatio="xMidYMid slice" aria-hidden="true" style="display: block; height: 160px;">
      {kind === "product" ? (
        <>
          <circle cx="900" cy="80" r="200" stroke="rgba(13,13,13,0.06)" stroke-width="1" fill="none"/>
          <circle cx="900" cy="80" r="100" stroke="rgba(13,13,13,0.07)" stroke-width="1" fill="none"/>
          <circle cx="900" cy="80" r="30" fill="rgba(13,13,13,0.05)"/>
          <line x1="0" y1="120" x2="700" y2="50" stroke="rgba(13,13,13,0.05)" stroke-width="1"/>
        </>
      ) : (
        <>
          <rect x="600" y="20" width="240" height="100" stroke="rgba(13,13,13,0.08)" stroke-width="1" fill="none"/>
          <rect x="680" y="50" width="200" height="90" stroke="rgba(13,13,13,0.06)" stroke-width="1" fill="none"/>
          <line x1="0" y1="140" x2="1200" y2="140" stroke="rgba(13,13,13,0.06)" stroke-width="1" stroke-dasharray="10 6"/>
          <rect x="80" y="60" width="8" height="8" fill="rgba(13,13,13,0.10)"/>
        </>
      )}
    </svg>
  </section>

  {pullQuote && (
    <section>
      <SectionRule />
      <Wrapper variant="standard" class="py-20 lg:py-28">
        <blockquote class="quote-block border-l-2 border-ink max-w-2xl">
          <p class="text-xl text-ink italic leading-relaxed">"{pullQuote.text}"</p>
          <cite class="mono-label text-ink-muted mt-6 block not-italic">— {pullQuote.cite}</cite>
        </blockquote>
      </Wrapper>
    </section>
  )}

  {caseStudy && (
    <section class="relative">
      <SectionRule />
      <Wrapper variant="standard" class="py-20 lg:py-28">
        <div class="max-w-3xl">
          <p class="mono-label text-ink-muted mb-8">CASE STUDY</p>
          <div class="border border-ghost-stroke p-6 sm:p-8 lg:p-12">
            <p class="mono-label text-ink-muted mb-4">{caseStudy.label}</p>
            <h3 class="font-display text-2xl font-bold tracking-tight text-ink leading-snug">
              {caseStudy.title}
            </h3>
            <div class="mt-6 flex flex-col gap-4 text-sm text-ink-muted leading-relaxed">
              {caseStudy.description.split("\n\n").map((paragraph: string) => (
                <p>{paragraph}</p>
              ))}
            </div>
            {caseStudy.metrics && caseStudy.metrics.length > 0 && (
              <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 border-t border-divider pt-6">
                {caseStudy.metrics.map((metric) => (
                  <div>
                    <p class="mono-label text-ink-muted mb-1">{metric.label}</p>
                    <p class="text-sm text-ink font-medium">{metric.value}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </Wrapper>
    </section>
  )}

  <section>
    <SectionRule />
    <Wrapper variant="standard" class="py-20 lg:py-32">
      <div class="max-w-3xl">
        <p class="mono-label text-ink-muted mb-6">CONTACT</p>
        <p class="text-base text-ink-muted leading-relaxed max-w-xl">{ctaText}</p>
        <a
          href="/contact"
          class="responsive-cta mt-8 bg-ink text-white text-sm font-medium px-6 py-3 hover:bg-ink-light transition-colors"
        >
          Contact Sales
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
