---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import BinderMark from "@/components/fundations/icons/BinderMark.astro";

const wallMemories = [
  {
    img: "/assets/pexels-rdne-5637731.jpg",
    title: "Three generations, one ledger",
    who: "Gifted privately",
  },
  {
    img: "/assets/pexels-olia-danilevich-8524992.jpg",
    title: "Where plans meet paper",
    who: "Stories & wills",
  },
  {
    img: "/assets/pexels-isabella-mendes-107313-30196897.jpg",
    title: "Fragments worth keeping",
    who: "Audio & prose",
  },
  {
    img: "/assets/pexels-anastasia-haritonov-898480-31316443.jpg",
    title: "The table stays set",
    who: "Traditions captured",
  },
  {
    img: "/assets/pexels-84327456-8972881.jpg",
    title: "Light after rain",
    who: "Places that shaped you",
  },
  {
    img: "/assets/pexels-vitalyagorbachev-26927324.jpg",
    title: "The road remembered",
    who: "Across borders",
  },
];

const heroCollage = [
  {
    img: "/assets/pexels-mart-production-7330707.jpg",
    alt: "Cherished photographs arranged with care",
    span: "row-span-2 row-start-1 col-start-1 h-full min-h-0",
  },
  {
    img: "/assets/pexels-mikhail-nilov-6957431.jpg",
    alt: "Reviewing albums and handwritten notes",
    span: "row-start-1 col-start-2 h-full min-h-0",
  },
  {
    img: "/assets/pexels-pavel-danilyuk-5789585.jpg",
    alt: "Family gathered with documents nearby",
    span: "row-start-2 col-start-2 h-full min-h-0",
  },
];

const phonePreview = wallMemories.slice(0, 4);

const features = [
  {
    n: "01",
    label: "Memories",
    description:
      "Every photo, audio note, and story you upload becomes legally authenticated property. Provenance recorded. Ownership established.",
    href: "/learn/memories",
  },
  {
    n: "02",
    label: "Wallets",
    description:
      "Group memories into wallets. Share, gift, license. The legal record travels with the asset — everywhere it goes.",
    href: "/learn/wallets",
  },
  {
    n: "03",
    label: "Marketplace",
    description:
      "An authenticated marketplace where personal property finds its value. Licensed. Traded. Gifted. Always with clear title.",
    href: "/marketplace",
  },
  {
    n: "04",
    label: "Registry",
    description:
      "An independent legal registry for consumer data and consumer agents. Real-time. Machine-readable. Operative across borders.",
    href: "/registry",
  },
];
---

<BaseLayout seo={{ title: "MemoryBinder — Legal property layer for your digital life" }}>
  <!-- Hero -->
  <section class="relative">
    <Wrapper variant="standard" class="pt-14 pb-16 lg:pt-20 lg:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-x-12 lg:gap-y-10 items-start">
        <div class="lg:col-span-5 min-w-0">
          <div class="eyebrow mb-5 lg:mb-6">
            <BinderMark size={30} variant="duo" glow={false} />
            <span>Legal property for personal memories</span>
            <span class="eyebrow-dot"></span>
            <span>iOS · Q3 2026</span>
          </div>
          <h1 class="page-hero-title text-ink kerning-display text-balance">
            <span class="block">MemoryBinder is the legal property layer</span>
            <span class="block text-mb-teal mt-2">for your digital life.</span>
          </h1>
          <p class="mt-6 lg:mt-7 max-w-xl text-base sm:text-lg leading-relaxed text-ink-soft font-grotesk font-normal">
            Photos, stories, audio, the moments that make a life — owned by you, recorded
            in law, portable everywhere they go.
          </p>
          <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 mt-10">
            <a href="/waitlist" class="btn-pink shimmer-hover">
              Try MemoryBinder
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/vision" class="btn-ghost"> Read the vision </a>
          </div>
        </div>

        <div class="lg:col-span-7 min-w-0 relative z-[1] lg:pt-2">
          <div class="grid grid-cols-2 grid-rows-2 gap-3 sm:gap-4 lg:gap-5 h-[min(58vw,420px)] sm:h-[340px] lg:h-[min(380px,36vw)] xl:h-[420px]">
            {heroCollage.map((c, i) => (
              <div
                class={`relative overflow-hidden rounded-2xl sm:rounded-[1.35rem] ${c.span} shadow-couture border border-divider-soft bg-wall-warm`}
              >
                <img
                  src={c.img}
                  alt={c.alt}
                  class="absolute inset-0 h-full w-full object-cover transition duration-700 ease-out hover:scale-[1.02]"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Manifesto -->
  <section class="relative">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10 gap-y-10 items-start">
        <h2 class="col-span-12 lg:col-span-5 section-title text-ink">
          When rights are clear,
          <span class="block mt-3 text-mb-teal font-display italic font-normal tracking-tight">everyone wins.</span>
        </h2>
        <div class="col-span-12 lg:col-span-6 lg:col-start-6">
          <div class="flex flex-col gap-6 text-base lg:text-lg leading-relaxed text-ink-soft font-grotesk">
            <p>
              The personal data economy is broken. Not because the supply does
              not exist. Because there is no legal infrastructure underneath it.
            </p>
            <p>
              Three and a half billion people generating unowned digital wealth
              every day. MemoryBinder builds the property rights underneath
              what they already do.
            </p>
            <p class="text-ink">
              <strong class="font-semibold">Not another pay-for-data platform.</strong>
              Payment without ownership is still extraction. We start earlier.
              Before the transaction. At the property right itself.
            </p>
          </div>
          <a href="/vision" class="inline-flex items-center gap-2 mt-10 text-sm font-semibold font-grotesk text-ink hover:text-mb-teal transition-colors">
            Read the full vision
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Editorial — real photography -->
  <section class="relative bg-wall-warm border-y border-divider">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="flex flex-col gap-5 sm:gap-6 lg:flex-row lg:items-end lg:justify-between mb-9 lg:mb-10">
        <h2 class="section-title text-ink max-w-[42rem] lg:max-w-none">
          Photos. Stories. Audio.<span class="block mt-1 text-mb-teal font-display italic tracking-tight">Moments that make a life.</span>
        </h2>
        <a href="/marketplace" class="btn-ghost shrink-0 self-start lg:self-auto">See the marketplace</a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-x-4 gap-y-10 sm:gap-x-5 sm:gap-y-11 lg:gap-x-6 lg:gap-y-12 justify-items-center">
        {wallMemories.map((m, i) => (
          <a
            href="/learn/memories"
            class={`group flex w-full max-w-[11.25rem] flex-col items-center text-center ${i % 2 === 0 ? "float-slow" : "float-med"}`}
          >
            <div class="memory-orb w-full">
              <img src={m.img} alt={m.title} loading="lazy" decoding="async" />
            </div>
            <p class="font-grotesk font-semibold text-sm text-ink mt-4 group-hover:text-mb-teal transition-colors leading-snug px-0.5">
              {m.title}
            </p>
            <p class="mt-1.5 font-mono text-[0.65rem] leading-relaxed tracking-wide text-ink-muted">
              {m.who}
            </p>
          </a>
        ))}
      </div>
    </Wrapper>
  </section>

  <!-- Four layers -->
  <section class="bg-wall">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10 gap-y-6 mb-14 lg:mb-16 items-baseline">
        <h2 class="col-span-12 lg:col-span-5 section-title text-ink">
          Four layers.
          <span class="block mt-2 text-lg sm:text-xl font-grotesk font-normal text-ink-muted leading-snug tracking-normal max-w-md">
            One property system built for everyday people — not jargon, not gimmicks.
          </span>
        </h2>
        <p class="col-span-12 lg:col-span-6 lg:col-start-6 text-base lg:text-lg text-ink-muted leading-relaxed max-w-xl font-grotesk">
          Each layer makes the next more valuable. Together, they put consumer
          personal data on the legal footing it has never had.
        </p>
      </div>

      <ol class="flex flex-col">
        {features.map((f) => (
          <li>
            <a
              href={f.href}
              class="feature-row group grid grid-cols-12 gap-x-6 lg:gap-x-10 gap-y-3 py-8 lg:py-10 border-t border-divider hover:border-mb-teal/35 transition-colors items-start"
            >
              <span class="col-span-2 lg:col-span-1 font-mono text-xs sm:text-sm tabular-nums tracking-[0.12em] text-ink-muted pt-1">
                {f.n}
              </span>
              <h3 class="col-span-10 lg:col-span-4 font-display font-normal text-[1.65rem] sm:text-[1.85rem] lg:text-[2.1rem] text-ink leading-[1.1] tracking-[-0.02em] group-hover:text-mb-teal transition-colors">
                {f.label}
              </h3>
              <p class="col-span-12 lg:col-span-6 text-sm lg:text-base text-ink-soft leading-relaxed font-grotesk">
                {f.description}
              </p>
              <span class="hidden lg:flex col-span-1 justify-end items-center pt-1 text-ink-muted group-hover:text-mb-teal transition-colors">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </Wrapper>
  </section>

  <!-- Pull quote -->
  <section class="relative overflow-hidden">
    <SectionRule />
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10 items-center">
        <div class="col-span-12 lg:col-span-2 hidden lg:flex justify-start opacity-85">
          <BinderMark size={88} variant="duo" />
        </div>
        <blockquote class="col-span-12 lg:col-span-9 lg:col-start-4">
          <p class="section-title text-ink">
            People keep doing what they love. Sharing memories. Gifting content.
            Telling their story. <span class="text-mb-teal font-display italic tracking-tight">MemoryBinder keeps that responsibility legally yours.</span>
          </p>
        </blockquote>
      </div>
    </Wrapper>
  </section>

  <!-- Preview strip + device -->
  <section class="border-t border-divider bg-wall-cool/40">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 order-2 lg:order-1">
          <p class="mono-label text-mb-teal-deep mb-4">Inside the binder</p>
          <h2 class="section-title text-ink mb-5">Designed like the gallery on your desk.</h2>
          <p class="text-ink-soft font-grotesk text-base lg:text-[1.05rem] leading-relaxed max-w-md">
            Wallets organise what matters. Memories stay portable. Marketplace and registry layers sit quietly behind —
            visible only when you need them.
          </p>
        </div>
        <div class="lg:col-span-7 order-1 lg:order-2">
          <div class="relative mx-auto max-w-[300px] sm:max-w-[340px]">
            <div class="phone-frame float-slow">
              <div class="phone-screen">
                <div class="phone-notch"></div>
                <div class="absolute inset-0 flex flex-col px-5 pt-12 pb-6 bg-wall">
                  <div class="flex items-center justify-between mb-4">
                    <p class="text-[10px] mono-label text-ink-muted">10:28</p>
                    <BinderMark size={22} variant="duo" glow={false} />
                  </div>
                  <p class="font-grotesk text-base font-semibold text-ink mb-1">Amani's Personal Wall</p>
                  <p class="mono-label text-ink-muted mb-4">12 memories · private</p>
                  <div class="grid grid-cols-2 gap-3 grow">
                    {phonePreview.map((m) => (
                      <div>
                        <div class="memory-orb rounded-2xl">
                          <img src={m.img} alt={m.title} loading="lazy" decoding="async" />
                        </div>
                        <p class="text-[11px] font-grotesk text-ink mt-2 leading-tight line-clamp-2">{m.title}</p>
                      </div>
                    ))}
                  </div>
                  <div class="flex items-center justify-around pt-3 mt-3 border-t border-divider">
                    <span class="mono-label text-ink-muted">create</span>
                    <span class="mono-label text-mb-teal font-medium">wallet</span>
                    <span class="mono-label text-ink-muted">market</span>
                    <span class="mono-label text-ink-muted">more</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="absolute -bottom-5 -right-2 sm:-right-5 rotate-3">
              <div class="bg-wall border border-divider-soft p-3 rounded-2xl shadow-[0_18px_30px_-16px_rgba(42,40,38,0.22)]">
                <div class="grid grid-cols-7 gap-[2px] w-[78px]">
                  {Array.from({ length: 49 }).map((_, i) => (
                    <span class={`block w-full aspect-square ${[0,1,2,5,6,7,9,11,12,14,15,16,18,20,23,24,26,28,30,31,33,35,38,40,42,43,44,46,47,48].includes(i) ? "bg-surface-dark" : ""}`}></span>
                  ))}
                </div>
                <p class="mono-label text-surface-dark mt-2 text-[8px] tracking-[0.18em]">App&nbsp;Store</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- CTA -->
  <section class="relative bg-surface-dark text-wall">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10 gap-y-10 items-end">
        <h2 class="col-span-12 lg:col-span-7 section-title">
          Be one of the <span class="text-mb-teal-soft font-display italic">first million</span>
          to legally own what they create.
        </h2>
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <p class="text-base lg:text-lg text-wall/72 leading-relaxed font-grotesk">
            500+ sign-ups across 23 countries. iOS launch Q3 2026.
            Get notified the moment we hit the App Store.
          </p>
          <a href="/waitlist" class="btn-pink shimmer-hover mt-8">
            Try MemoryBinder
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
