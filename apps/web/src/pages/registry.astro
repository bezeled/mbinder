---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import BinderMark from "@/components/fundations/icons/BinderMark.astro";

const capabilities = [
  { label: "AUTHENTICATE", description: "Register a memory, wallet, or agent and produce a legally operative record of provenance and ownership." },
  { label: "VERIFY", description: "Any organisation can verify the registry against a given asset. Real-time, machine-readable, court-recognised." },
  { label: "TRANSFER", description: "Move title with the asset. Gifts, sales, licences — every change of hands recorded automatically." },
  { label: "ATTACH", description: "Link real-world legal events — contracts, certificates, agreements — to the digital record via Smart Legal Contracts." },
];

const layers = [
  { label: "Identity layer", value: "Cryptographic identity for every consumer, every agent, every authenticated asset." },
  { label: "Provenance layer", value: "Append-only legal record. Authentications, transfers, licences, agent actions." },
  { label: "Smart Legal Contract layer", value: "Programmable legal agreements that perform their own obligations." },
  { label: "Verification API", value: "An open endpoint for enterprise and government compliance to query the legal record." },
];

const principles = [
  { n: "01", title: "Independence", description: "The registry is held by an independent Data Trust. Not the commercial entity." },
  { n: "02", title: "Interoperability", description: "Built on open legal protocols. Other organisations can build directly against the registry." },
  { n: "03", title: "Append-only truth", description: "Records are not edited. Updates are appended. The history of any asset is permanent." },
  { n: "04", title: "Consumer first", description: "Every record names a person — not a platform — as the rights holder." },
];

const provenanceEntries = [
  { hash: "7f3a·c8d2·91e0·a4b7·0f28", status: "AUTH", pending: false },
  { hash: "a1b9·4e77·d3f0·8c25·6a91", status: "AUTH", pending: false },
  { hash: "3d82·f105·b7c4·2e68·9d03", status: "TRSF", pending: false },
  { hash: "c9f7·81a6·e2d5·4b39·1c70", status: "AUTH", pending: false },
  { hash: "52e4·0d93·a8f6·7b12·c5de", status: "LICN", pending: false },
  { hash: "8a16·b3c7·d094·5ef2·a1b8", status: "····", pending: true },
];
---

<BaseLayout seo={{ title: "Registry" }}>
  <!-- Hero -->
  <section class="relative">
    <Wrapper variant="standard" class="pt-24 pb-16 lg:pt-32 lg:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-7"><span class="eyebrow-dot"></span>The Registry</p>
          <h1 class="page-hero-title text-ink">
            The independent legal layer <span class="couture-wonky text-mb-pink">underneath the app.</span>
          </h1>
          <p class="mt-8 max-w-xl text-base lg:text-lg leading-relaxed text-ink-muted">
            The MemoryBinder Registry is the world's first independent legal
            registry for personal data and consumer AI agents. Real-time.
            Machine-readable. Operative across organisational and national
            boundaries.
          </p>
        </div>
        <div class="lg:col-span-5 lg:pt-12">
          <div class="font-mono text-[10px] tracking-wider leading-none p-6 bg-wall border border-divider rounded-2xl">
            {provenanceEntries.map((entry, i) => (
              <>
                <div class="flex items-center gap-3 py-[6px]">
                  <span class={`block w-[6px] h-[6px] shrink-0 ${entry.pending ? "border border-mb-pink" : "bg-mb-pink"}`}></span>
                  <span class="min-w-0 flex-1 break-all text-ink-muted">{entry.hash}</span>
                  <span class={`shrink-0 tracking-[0.18em] ${entry.pending ? "text-mb-pink animate-pulse" : "text-ink"}`}>{entry.status}</span>
                </div>
                {i < provenanceEntries.length - 1 && (
                  <div class="ml-[2px] w-px h-3 bg-divider"></div>
                )}
              </>
            ))}
          </div>
          <p class="mono-label text-ink-muted mt-4">Live registry events · sample</p>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Capabilities -->
  <section>
    <SectionRule />
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <p class="mono-label text-mb-pink mb-12">CORE CAPABILITIES</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {capabilities.map((c) => (
          <div class="border-t border-ink pt-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="geo-dot"></span>
              <span class="mono-label text-ink font-medium">{c.label}</span>
            </div>
            <p class="text-sm text-ink-muted leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>
    </Wrapper>
  </section>

  <!-- Architecture -->
  <section class="bg-wall-warm border-y border-divider">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <p class="mono-label text-mb-pink mb-6">ARCHITECTURE</p>
          <h2 class="couture text-[clamp(2rem,5vw,3.4rem)] text-ink">
            Four layers. <span class="couture-wonky text-mb-pink">One legal truth.</span>
          </h2>
          <div class="mt-8 flex justify-start">
            <BinderMark size={120} variant="duo-purple" />
          </div>
        </div>
        <div class="lg:col-span-7 space-y-6">
          {layers.map((l) => (
            <div class="border-t border-ink pt-5">
              <p class="mono-label text-mb-pink mb-2">{l.label}</p>
              <p class="text-base text-ink-soft leading-relaxed">{l.value}</p>
            </div>
          ))}
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Principles -->
  <section>
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <p class="mono-label text-mb-pink mb-12">PRINCIPLES</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {principles.map((p) => (
          <div class="border-t border-ink pt-6">
            <p class="mono-label text-ink-muted mb-3">No. {p.n}</p>
            <h3 class="couture text-2xl lg:text-3xl text-ink mb-3">{p.title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </Wrapper>
  </section>

  <!-- CTA -->
  <section class="bg-ink text-wall">
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-8">
          <h2 class="couture text-3xl lg:text-5xl">
            Build against the registry.
            <span class="couture-wonky text-mb-pink">Or just live above it.</span>
          </h2>
        </div>
        <div class="lg:col-span-4 flex flex-col gap-3">
          <a href="/contact" class="btn-pink w-full">Talk to us</a>
          <a href="/trust" class="btn-ghost text-wall border-wall hover:bg-wall hover:text-ink w-full">Read the Trust</a>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
