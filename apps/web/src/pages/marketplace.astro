    height: 86%;
    object-fit: contain;
    object-position: center;
    filter: drop-shadow(0 24px 30px rgba(0, 0, 0, 0.45));
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .wallet-card {
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
