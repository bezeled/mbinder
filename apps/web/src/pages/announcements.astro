---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import { getAllNewsPosts } from "@/lib/data";

const announcementEntries = (await getAllNewsPosts()).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <div class="geo-circle hidden lg:block" style="width: 450px; height: 450px; top: -100px; right: -150px;"></div>
    <Wrapper variant="standard" class="pt-24 pb-16 lg:pt-36 lg:pb-24">
      <div class="max-w-3xl">
        <p class="mono-label text-ink-muted mb-6">NEWS</p>
        <h1 class="page-hero-title text-ink">
          Announcements
        </h1>
        <p class="mt-8 text-base text-ink-muted leading-relaxed max-w-xl">
          Product launches, partnerships, milestones and infrastructure updates from MemoryBinder.
        </p>
      </div>
    </Wrapper>
  </section>

  <section>
    <SectionRule />
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="flex flex-col">
        {announcementEntries.length > 0 ? (
          announcementEntries.map((announcement) => (
            <a
              href={`/announcements/${announcement.slug}`}
              class="block border-t border-divider py-6 -mx-4 px-4 hover:bg-linen-dark/30 transition-colors"
            >
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
                <div>
                  <p class="mono-label text-ink-muted">{announcement.data.category.toUpperCase()}</p>
                  <h2 class="text-lg font-medium text-ink mt-1">{announcement.data.title}</h2>
                  {announcement.data.excerpt && (
                    <p class="text-sm text-ink-muted mt-2 max-w-2xl leading-relaxed">
                      {announcement.data.excerpt}
                    </p>
                  )}
                </div>
                <time class="mono-label text-ink-muted whitespace-nowrap" datetime={announcement.data.publishedAt.toISOString()}>
                  {announcement.data.publishedAt.toLocaleDateString("en-GB", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })}
                </time>
              </div>
            </a>
          ))
        ) : (
          <div class="border-t border-divider py-6">
            <p class="text-sm leading-relaxed text-ink-muted">
              Announcements will appear here as they are published.
            </p>
          </div>
        )}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
