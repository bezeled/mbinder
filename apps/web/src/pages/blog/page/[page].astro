---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import Pagination from "@/components/listing/Pagination.astro";
import { getAllBlogPosts } from "@/lib/data";
import {
  getPageCount,
  getPageItems,
  LIST_PAGE_SIZE,
} from "@/lib/listing/pagination";

type BlogEntry = {
  slug: string;
  data: {
    headline: string;
    subheadline: string;
    publishedAt: Date;
    heroImage?: {
      url: string;
      alt: string;
    };
  };
};

export async function getStaticPaths() {
  const blogEntries = (await getAllBlogPosts()).sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  );
  const totalPages = getPageCount(blogEntries.length, LIST_PAGE_SIZE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;

    return {
      params: { page: String(page) },
    };
  });
}

const currentPage = Number(Astro.params.page);
const blogEntries: BlogEntry[] = (await getAllBlogPosts()).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const totalPages = getPageCount(blogEntries.length, LIST_PAGE_SIZE);

if (!Number.isInteger(currentPage) || currentPage < 2 || currentPage > totalPages) {
  return Astro.redirect("/404");
}

const paginatedBlogEntries = getPageItems(
  blogEntries,
  currentPage,
  LIST_PAGE_SIZE
);
---

<BaseLayout seo={{ title: `Blog Page ${currentPage}` }}>
  <section class="relative">
    <Wrapper variant="standard" class="pt-24 pb-16 lg:pt-36 lg:pb-24">
      <div class="max-w-3xl">
        <h1 class="page-hero-title text-ink">Blog</h1>
        <p class="mt-8 text-base text-ink-muted leading-relaxed max-w-xl">
          Notes on AI agents, legal infrastructure, data rights, and the governance questions that decide whether deployment can scale safely.
        </p>
      </div>
    </Wrapper>
  </section>

  <section>
    <SectionRule />
    <Wrapper variant="standard" class="py-20 lg:py-28">
      <div class="grid grid-cols-1 gap-12">
        {paginatedBlogEntries.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group grid grid-cols-1 gap-8 border-t border-divider pt-8 transition-colors hover:bg-linen-dark/30 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1fr)] lg:-mx-4 lg:px-4"
          >
            <div class="img-editorial overflow-hidden border border-ghost-stroke bg-linen-dark">
              {post.data.heroImage?.url ? (
                <img
                  src={post.data.heroImage.url}
                  alt={post.data.heroImage.alt || post.data.headline}
                  class="w-full aspect-[16/10] object-cover"
                  loading="lazy"
                />
              ) : null}
            </div>
            <div class="flex flex-col justify-center">
              <p class="mono-label text-ink-muted">BLOG</p>
              <time class="mono-label text-ink-muted mt-3 block" datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString("en-GB", {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })}
              </time>
              <h2 class="mt-3 text-2xl font-medium leading-tight text-ink lg:text-4xl group-hover:underline">
                {post.data.headline}
              </h2>
              <p class="mt-5 text-sm leading-relaxed text-ink-muted lg:text-base">
                {post.data.subheadline}
              </p>
            </div>
          </a>
        ))}
      </div>

      <Pagination basePath="/blog" currentPage={currentPage} totalPages={totalPages} />
    </Wrapper>
  </section>
</BaseLayout>
