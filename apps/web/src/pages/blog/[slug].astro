---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import SectionRule from "@/components/fundations/containers/SectionRule.astro";
import { getAllBlogPosts, getBlogPostBySlug } from "@/lib/data";
import { portableTextToHtml } from "@/lib/sanity";

type BlogEntry = {
  slug: string;
  data: {
    headline: string;
    subheadline: string;
    publishedAt: Date;
    heroImage?: {
      url: string;
      alt: string;
    };
  };
  body?: unknown[];
};

export async function getStaticPaths() {
  const blogPosts = await getAllBlogPosts();

  return blogPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const cmsPost = slug ? await getBlogPostBySlug(slug) : null;

if (!cmsPost) {
  return Astro.redirect("/404");
}

const post: BlogEntry = cmsPost;
const bodyHtml =
  cmsPost?.body && cmsPost.body.length > 0
    ? portableTextToHtml(cmsPost.body)
    : "";
const seo = {
  title: post.data.headline,
  description: post.data.subheadline,
  image: post.data.heroImage,
  type: "article" as const,
};
---

<BaseLayout seo={seo}>
  <article>
    <section class="relative overflow-hidden">
      <div class="geo-circle hidden lg:block" style="width: 520px; height: 520px; top: -160px; right: -180px;"></div>
      <Wrapper variant="standard" class="pt-24 pb-16 lg:pt-36 lg:pb-20">
        <div class="max-w-5xl">
          <a href="/blog" class="mono-label text-ink-muted hover:text-ink transition-colors">
            Back to blog
          </a>
          <p class="mono-label text-ink-muted mt-8">BLOG</p>
          <time class="mono-label text-ink-muted mt-4 block" datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en-GB", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })}
          </time>
          <h1 class="mt-6 text-4xl lg:text-6xl font-medium text-ink leading-tight max-w-5xl">
            {post.data.headline}
          </h1>
          <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink">
            {post.data.subheadline}
          </p>
          <div class="mt-10 overflow-hidden border border-ghost-stroke bg-linen-dark">
            {post.data.heroImage?.url ? (
              <img
                src={post.data.heroImage.url}
                alt={post.data.heroImage.alt || post.data.headline}
                class="w-full aspect-[16/9] object-cover"
                loading="eager"
              />
            ) : null}
          </div>
        </div>
      </Wrapper>
    </section>

    <section>
      <SectionRule />
      <Wrapper variant="standard" class="py-20 lg:py-28">
        <div class="max-w-3xl">
          {bodyHtml ? (
            <div
              class="prose prose-sm max-w-none text-ink-muted leading-relaxed"
              set:html={bodyHtml}
            />
          ) : null}
        </div>
      </Wrapper>
    </section>
  </article>
</BaseLayout>
